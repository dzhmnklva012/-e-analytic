{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "login-preview",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-Command", "$h=New-Object Net.HttpListener;$h.Prefixes.Add('http://localhost:3000/');$h.Start();while($h.IsListening){$c=$h.GetContext();$p=$c.Request.Url.LocalPath;if($p -eq '/' -or $p -eq ''){$f='C:\\Users\\Avrora\\Desktop\\Adata\\login.html'}else{$f='C:\\Users\\Avrora\\Desktop\\Adata'+$p};if(Test-Path $f){$ext=[IO.Path]::GetExtension($f);$mt=if($ext -eq '.html'){'text/html'}elseif($ext -eq '.css'){'text/css'}elseif($ext -eq '.js'){'application/javascript'}else{'application/octet-stream'};$c.Response.ContentType=$mt;$b=[IO.File]::ReadAllBytes($f);$c.Response.ContentLength64=$b.Length;$c.Response.OutputStream.Write($b,0,$b.Length)}else{$c.Response.StatusCode=404};$c.Response.Close()}"],
      "port": 3000
    },
    {
      "name": "anticor-preview",
      "runtimeExecutable": "powershell",
